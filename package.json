
{
  "name": "transcendence",
  "version": "1.0.0",
  "description": "A Node.js + Typescript + Fastify + Tailwind CSS server",
  "scripts": {
    "dev": "ts-node src/main.ts",
    "build:css": "tailwindcss -i client/src/input.css -o client/dist/output.css --minify",
    "build": "tsc && npm run build:css",
    "start": "node dist/main.js"
  },
  "dependencies": {
    "@fastify/multipart": "^7.7.3",
    "@fastify/cookie": "^9.1.0",        
    "@fastify/cors": "^8.4.1",          
    "@fastify/static": "^6.12.0",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.3.1",            
    "fastify": "^4.29.1",
    "fastify-plugin": "^4.5.1",         
    "jsonwebtoken": "^9.0.2",
    "speakeasy": "^2.0.0",
    "sqlite3": "^5.1.6",                
    "sharp": "^0.33.5",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/speakeasy": "^2.0.10",
    "@types/sqlite3": "^3.1.10",
    "@types/ws": "^8.5.10",             
    "@types/node": "^18.19.3",        
    "autoprefixer": "^10.4.16",   
    "postcss": "^8.4.31",              
    "tailwindcss": "^3.3.5",     
    "ts-node": "^10.9.2",           
    "typescript": "^5.0.4"
  }
}